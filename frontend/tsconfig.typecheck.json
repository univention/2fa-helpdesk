{
    "compilerOptions": {
      "strict": true,
      "paths": { "@/*": ["./src/*"] },
      "skipLibCheck": true,
      "noUnusedLocals": true,
      "noUnusedParameters": true,
      "module": "esnext",
      "target": "esnext",
      "moduleResolution": "bundler"
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "api"]
  }
